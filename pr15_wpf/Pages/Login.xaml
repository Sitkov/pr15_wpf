<Page x:Class="pr15_wpf.Pages.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr15_wpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация">

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="250px">
        <Button Content="Войти как посетитель" Click="GoGuest"
                FontSize="20px" Cursor="Hand" Height="40"/>
        <PasswordBox Name="PINKOD" Height="30" 
                     Background="#00C4B4" 
                     BorderThickness="3" Margin="0 10 0 5"
                     BorderBrush="#00b4c4" VerticalContentAlignment="Center
                     " HorizontalContentAlignment="Center" ></PasswordBox>
        <Button Content="Manager" Click="GoManager"
                FontSize="20px" Height="40"/>
    </StackPanel>
</Page>
