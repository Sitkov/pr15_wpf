<Page x:Class="pr15_wpf.Pages.AddChangeProduct"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr15_wpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddChangeProduct">

    <Grid Margin="10">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" Grid.Column="1" Margin="10">
            <Label Content="Наименование"/>
            <TextBox Text="{Binding SelectedProduct.Name, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Описание"/>
            <TextBox Text="{Binding SelectedProduct.Description, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Цена"/>
            <TextBox Text="{Binding SelectedProduct.Price, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Остаток"/>
            <TextBox Text="{Binding SelectedProduct.Stock, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Категория"/>
            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedProduct.Category}" DisplayMemberPath="Name"/>

            <Label Content="Бренд"/>
            <ComboBox ItemsSource="{Binding Brands}" SelectedItem="{Binding SelectedProduct.Brand}" DisplayMemberPath="Name"/>

            <TextBlock Text="Теги:" Margin="5" VerticalAlignment="Center"/>
            <ListBox x:Name="lbTags" Margin="5" Height="90" SelectionMode="Multiple"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Сохранить" Margin="0,0,10,0" Click="SaveProduct_Click"/>
                <Button Content="Назад" Click="Back"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
