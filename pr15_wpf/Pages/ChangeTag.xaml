<Page x:Class="pr15_wpf.Pages.ChangeTag"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr15_wpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChangeTag"
      Loaded="LoadPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Настройка ТЕГОВ" FontSize="32" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <StackPanel Grid.Row="2" VerticalAlignment="top" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBox x:Name="BrandNameTxt" Text="{Binding ElementName=TagsList, Path=SelectedItem.Name, UpdateSourceTrigger=Explicit}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Добавить" Click="AddBtn_Click" Margin="5" Width="100"/>
                <Button Content="Редактировать" Click="EditBtn_Click" Margin="5"/>
                <Button Content="Удалить" Click="DeleteBtn_Click" Margin="5" Width="100" Background="Red" BorderBrush="Red"/>
                <Button Content="Назад" Click="Back" Margin="5" />
            </StackPanel>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="TagsList" DisplayMemberPath="Name">
        </ListView>
    </Grid>
</Page>
